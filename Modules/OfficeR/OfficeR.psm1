<# InstallDropdown Functions #>
function Set-InstallDropdown { 
    param ( $control )
    if (-not $control) { return }

    $list = Get-Control $control "LicenseList"
    if ($list) {
        $list.Items.Clear()
        [void]$list.Items.AddRange($Offices.Keys)
        $list.SelectedIndex = 0
    }
    return
}
function Update-InstallDropdown {
    param ( $control )
    if (-not $control) { return }

    :outer foreach ($key in $Offices.Keys) {
        foreach($subkey in $Offices[$key].Keys) {
            if ($control.SelectedItem -eq $subkey) {
                $list = Get-Control $control "EditionList"
                $items = $Offices[$key][$subkey].Keys
                break outer
            }
        }
        if ($control.SelectedItem -eq $key) { 
            $list = Get-Control $control "VersionList"
            $items = $Offices[$key].Keys
            break outer
        }
    }
    if ($list -and $items) {
        $list.Items.Clear()
        $list.Items.AddRange($items)
        $list.SelectedIndex = 0
    }
}

Set-Alias Set-OfficeDropdown Update-OfficeDropdown
function Update-OfficeDropdown {
    param ( $control )
    if (-not $control) { return }

    $officeLists        = @("InstalledOfficeList", "ActivateOfficeList") | ForEach-Object { Get-Control $control $_ }
    $installedOffice   = Get-C2RProducts | ForEach-Object { $_.ProductID } | Sort-Object

    foreach ($list in $officeLists) {
        if (-not $list) { return }
        $list.Items.Clear()

        if ($installedOffice) { $list.Items.AddRange($installedOffice) } 
        else { $list.Items.Add("-kein Office installiert-") }
        $list.SelectedIndex = 0
    }
}

function Get-C2RProducts {    
    function Get-OfficeLicenseStatusWMI {
        try {
            $licenses = Get-CimInstance -ClassName SoftwareLicensingProduct -Filter "ApplicationID='0ff1ce15-a989-479d-af46-f275c6370663' AND PartialProductKey IS NOT NULL" -ErrorAction SilentlyContinue

            if (-not $licenses) { $licenses = Get-WmiObject -Query "SELECT LicenseStatus FROM SoftwareLicensingProduct WHERE ApplicationId='0ff1ce15-a989-479d-af46-f275c6370663' AND PartialProductKey IS NOT NULL" -ErrorAction SilentlyContinue }
            if (-not $licenses) { return "No License Found" }
            
            foreach ($license in $licenses) { if ($license.LicenseStatus -eq 1) { return "Licensed" } }
            
            $firstLicense = $licenses | Select-Object -First 1
            switch ($firstLicense.LicenseStatus) {
                0 { return "Unlicensed" }
                1 { return "Licensed" }
                2 { return "OOB Grace" }
                3 { return "OOT Grace" }
                4 { return "Non-Genuine Grace" }
                5 { return "Notification" }
                6 { return "Extended Grace" }
                default { return "Unknown" }
            }
        }
        catch {
            Write-Warning "WMI-Abfrage fehlgeschlagen: $_"
            return "Unknown"
        }
    }
    function Get-OfficeProductIndex {
        $index = [ordered]@{}

        foreach ($licenseType in $Offices.Keys) {
            foreach ($bundle in $Offices[$licenseType].Keys) {
                foreach ($edition in $Offices[$licenseType][$bundle].Keys) {
                    $productId = "$edition$licenseType"
                    $index[$productId] = [PSCustomObject]@{
                        ProductID       = $productId
                        ProductKey      = $Offices[$licenseType][$bundle][$edition]
                        ProductBundle   = $bundle
                        LicenseType     = $licenseType
                        Edition         = $edition
                    }
                }
            }
        }

        return $index
    }
    
    $reg            = "HKLM:\SOFTWARE\Microsoft\Office\ClickToRun\Configuration"
    $products       = @()
    $productIndex   = Get-OfficeProductIndex
    

    if (Test-Path $reg) {
        $props = Get-ItemProperty $reg
        $ids   = $props.ProductReleaseIds -split "," | ForEach-Object { $_.Trim() } | Where-Object { $_ }

        foreach ($id in $ids) {
            # Lizenzstatus per WMI abrufen
            $licenseStatus = Get-OfficeLicenseStatusWMI
            
            # ProductKey ermitteln
            $product        = $productIndex[$id]
            $productKey     = if ($product) { $product.ProductKey } else { $null }
            $productBundle  = if ($product) { $product.ProductBundle } else { $null }
                       
            $products += [PSCustomObject]@{
                ProductID       = $id
                ProductKey      = $productKey
                ProductBundle   = $productBundle
                Version         = $props.ClientVersionToReport
                Edition         = $id -replace '(Volume|Retail)$', ''
                LicenseStatus   = $licenseStatus
                IsActivated     = ($licenseStatus -eq "Licensed")
            }
        }
        if ($products.Count -eq 0) {
            $products += [PSCustomObject]@{
                ProductID       = "Unknown"
                ProductKey      = "Unknown"
                ProductBundle   = "Unknown"
                Version         = $props.ClientVersionToReport
                Edition         = "Unknown"
                LicenseStatus   = "Unknown"
                IsActivated     = $false
            }
        }
    }
    return $products
}





function Get-OfficeDownloadURL {
    param (
        [string]$productID,
        [string]$language   = "de-de",
        [string]$version    = "O16GA",
        [string]$platform   = "x64",
        [string]$internet
    )
    if ($internet -eq "Offline") {
        return "https://officecdn.microsoft.com/db/492350f6-3a01-4f97-b9c0-c7c6ddf67d60/media/" + $language + "/" + $productID + ".img"
    }
    # Anpassung der Plattformbezeichnung
    if ($platform -eq "x86") { $platform = "x32" }
    return "https://c2rsetup.officeapps.live.com/c2r/download.aspx?ProductreleaseID=" + $productID + "&platform=" + $platform + "&language=" + $language + "&version=" + $version
}
function Install-Office {
    param ( $control, $internet, $architecture )
    if (-not $control) { return }
    Hide-Window $control.FindForm()
    Show-ProgressDialog "Office Installation" "Starte Office-Installation..." -Control $control

    $license = (Get-Control $control "LicenseList").SelectedItem
    $version = (Get-Control $control "VersionList").SelectedItem
    $edition = (Get-Control $control "EditionList").SelectedItem

    Update-ProgressDialog "Ermittle URL für $license $version $edition ($architecture, $internet)..."
    $productID      = if ($Offices.Contains($license)) { $edition + $license } else { $edition }
    $downloadURL    = Get-OfficeDownloadURL -productID $productID -language "de-de" -platform $architecture -internet $internet
    Update-ProgressDialog "Ermittelt: $downloadURL"


    $fileName = if ($internet -eq "Offline") { "$($productID)_installer.img" } else { "$($productID)_installer.exe" }
    $tempFile    = [System.IO.Path]::Combine([System.IO.Path]::GetTempPath(), $fileName)
    Update-ProgressDialog "Ermittle temporäre Datei: $tempFile"

    Update-ProgressDialog "Starte Download von $edition..."
    Request-File -Url $downloadURL -File $tempFile

    Update-ProgressDialog "Starte $fileName..."
    if ($internet -eq "Offline") {
        try {
            $mount = Mount-DiskImage -ImagePath $tempFile -PassThru -ErrorAction Stop
            $volume = $mount | Get-Volume -ErrorAction Stop | Select-Object -First 1
        } catch {
            throw "Das Office-Installationsimage konnte nicht eingebunden werden oder das Volume konnte nicht ermittelt werden: $tempFile"
        }

        $driveLetter = $volume.DriveLetter
        $setupFile = "${driveLetter}:\setup.exe"
    } else { $setupFile = $tempFile }
    $installationSucceeded = $false
    try {
        $process = Start-Process -FilePath $setupFile -PassThru -ErrorAction Stop

        # Einige Office-Installer schließen ihr UI, laufen aber im Hintergrund weiter.
        # Daher warten wir mit Timeout und halten die UI responsiv.
        $timeoutSeconds = 3600
        $stopwatch = [System.Diagnostics.Stopwatch]::StartNew()
        while (-not $process.HasExited) {
            if ($stopwatch.Elapsed.TotalSeconds -ge $timeoutSeconds) {
                throw "Office-Installation hat das Timeout von $timeoutSeconds Sekunden überschritten (PID: $($process.Id))."
            }

            Start-Sleep -Milliseconds 500
            if ("System.Windows.Forms.Application" -as [type]) { [System.Windows.Forms.Application]::DoEvents() }
        }

        if ($process.ExitCode -ne 0) {
            throw "Office-Setup wurde mit ExitCode $($process.ExitCode) beendet."
        }

        $installationSucceeded = $true
        Update-ProgressDialog "Office Installation" "$edition erfolgreich installiert."
    }
    finally {
        # Show-Window $control.FindForm()
        if ($internet -eq "Offline") { Dismount-DiskImage -ImagePath $tempFile -ErrorAction SilentlyContinue }

        if ($installationSucceeded) {
            Update-ProgressDialog "Office Installation" "Lösche temporäre Datei..."
            Remove-Item -Path $tempFile -Force -ErrorAction SilentlyContinue
            Close-ProgressDialog "Office Installation abgeschlossen." -Control $control
        } else {
            Close-ProgressDialog "Office Installation fehlgeschlagen." -Control $control
        }
        Show-Window $control.FindForm()
    }
}


<# OFFICE ENTFERNEN #>
function Uninstall-Office {
    param ( $control, [string]$ProductID )
    Show-ProgressDialog "Office Deinstallation" "Starte Office-Deinstallation..." -Control $control

    # Wenn kein ProductID-Parameter übergeben wurde, versuche ihn aus der UI zu ermitteln
    if (-not $ProductID -and $control) {
        $dropdownList = if ($control.Parent -and $control.Parent.Controls.ContainsKey("InstalledOfficeList")) { $control.Parent.Controls["InstalledOfficeList"] } 
                        elseif ($control.FindForm()) { $control.FindForm().Controls.Find("InstalledOfficeList", $true) | Select-Object -First 1 } 
                        else { Get-Control $control "InstalledOfficeList" }

        if ($dropdownList) { $ProductID = [string]$dropdownList.SelectedItem }
        else { Write-Warning "Keine Möglichkeit gefunden, die ausgewählte Office-Produkt-ID zu ermitteln."; return }
    }

    
    Stop-OfficeProcesses # Beende alle Office-bezogenen Prozesse, um Deinstallationshindernisse zu minimieren

    # Suche nach Deinstallationseinträgen, zuerst gezielt nach der ProductID, dann allgemein
    $uninstallEntries = Get-OfficeUninstallEntries -ProductID $ProductID
    if (-not $uninstallEntries -and $ProductID) { $uninstallEntries = Get-OfficeUninstallEntries }
    if (-not $uninstallEntries) { Close-ProgressDialog "Keine Office-Deinstallationseinträge gefunden."; return }

    Update-ProgressDialog "Gefundene Office-Deinstallationseinträge: $($uninstallEntries.Count)"
    foreach ($entry in $uninstallEntries) {
        $commandLine = if ($entry.QuietUninstallString) { $entry.QuietUninstallString } else { $entry.UninstallString }

        # Versuche, den Deinstallationsbefehl zu normalisieren und die ausführbare Datei zu extrahieren
        $command     = Resolve-OfficeUninstallCommand -CommandLine $commandLine
        if (-not $command -or -not (Test-Path $command.FilePath) -and $command.FilePath -notmatch '(?i)msiexec(?:\.exe)?$') {
            Update-ProgressDialog "Überspringe ungültigen Deinstallationsbefehl: $($entry.DisplayName)"
            continue
        }

        Update-ProgressDialog "Deinstalliere $($entry.DisplayName)..."
        Hide-Window $control.FindForm()
        $process = Start-Process -FilePath $command.FilePath -ArgumentList $command.Arguments -Wait -PassThru -ErrorAction SilentlyContinue
        Show-Window $control.FindForm()

        if ($process -and $process.ExitCode -ne 0) { Update-ProgressDialog "Deinstallation meldet ExitCode $($process.ExitCode): $($entry.DisplayName)" } 
    }

    $remainingProducts  = @(Get-C2RProducts)
    $remainingEntries   = @(Get-OfficeUninstallEntries)

    if ($remainingProducts.Count -eq 0 -and $remainingEntries.Count -eq 0) {
        Update-ProgressDialog "Keine Office-Produkte mehr gefunden, entferne Reste..."
        Remove-OfficeResiduals
    } else {
        Update-ProgressDialog "Es sind noch Office-Einträge vorhanden, Restbereinigung wird konservativ ausgelassen."
    }
    Close-ProgressDialog "Office-Deinstallation abgeschlossen." -Control $control
}
function Stop-OfficeProcesses {
    Update-ProgressDialog "Beende alle Office-bezogenen Prozesse..."
    $processNames = @( 'WINWORD', 'EXCEL', 'POWERPNT', 'OUTLOOK', 'ONENOTE', 'MSACCESS', 'MSPUB', 'VISIO', 'LYNC', 'OfficeClickToRun' )
    $serviceNames = @( 'ClickToRunSvc', 'OfficeSvc' )
    
    foreach ($processName in $processNames) { Get-Process -Name $processName | Stop-Process -InputObject $process -Force }

    foreach ($serviceName in $serviceNames) {
        $service = Get-Service -Name $serviceName
        if ($service -and $service.Status -ne 'Stopped') { Stop-Service -Name $serviceName -Force }
    }
}
function Get-OfficeUninstallEntries {
    param ( [string]$ProductID )
    if ($ProductID) { Update-ProgressDialog "Suche nach Deinstallationseinträgen für ProductID: $ProductID..." } 
    else { Update-ProgressDialog "Suche nach allen Office-Deinstallationseinträgen..." }

    $uninstallPaths = @(
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall",
        "HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall"
    )
    $officePattern = 'Microsoft (Office|365|Visio|Project|Access|Publisher|OneNote|Excel|Word|Outlook|PowerPoint)|Office 16 Click-to-Run'
    $entries = foreach ($path in $uninstallPaths) {
        if (-not (Test-Path $path)) { continue }

        foreach ($item in Get-ChildItem -Path $path -ErrorAction SilentlyContinue) {
            $props = Get-ItemProperty -Path $item.PSPath -ErrorAction SilentlyContinue
            if (-not $props) { continue }

            $displayName          = [string]$props.DisplayName
            $uninstallString      = [string]$props.UninstallString
            $quietUninstallString = [string]$props.QuietUninstallString
            $installLocation      = [string]$props.InstallLocation
            $publisher            = [string]$props.Publisher

            $isOfficeEntry =
                $displayName -match $officePattern -or
                $uninstallString -match 'OfficeClickToRun|Office' -or
                $quietUninstallString -match 'OfficeClickToRun|Office' -or
                $installLocation -match 'Microsoft Office'

            if (-not $isOfficeEntry) { continue }

            $productIds = [System.Collections.Generic.List[string]]::new()
            if ($props.PSObject.Properties.Name -contains 'ProductReleaseIds' -and $props.ProductReleaseIds) {
                foreach ($id in ($props.ProductReleaseIds -split ',')) {
                    $trimmedId = $id.Trim()
                    if ($trimmedId) { [void]$productIds.Add($trimmedId) }
                }
            }

            foreach ($command in @($uninstallString, $quietUninstallString)) {
                if (-not $command) { continue }
                if ($command -match 'productstoremove=([^\s]+)') {
                    foreach ($id in ($Matches[1] -split ',')) {
                        $normalizedId = ($id.Trim() -split '\.')[0]
                        if ($normalizedId -and -not $productIds.Contains($normalizedId)) {
                            [void]$productIds.Add($normalizedId)
                        }
                    }
                }
            }

            if ($ProductID) {
                $matchesProduct = $productIds.Contains($ProductID) -or $uninstallString -like "*$ProductID*" -or $quietUninstallString -like "*$ProductID*"
                if (-not $matchesProduct) { continue }
            }

            [PSCustomObject]@{
                DisplayName            = $displayName
                RegistryPath           = $item.PSPath
                UninstallString        = $uninstallString
                QuietUninstallString   = $quietUninstallString
                InstallLocation        = $installLocation
                Publisher              = $publisher
                ProductIds             = @($productIds)
                IsClickToRun           = ($uninstallString -match 'OfficeClickToRun' -or $quietUninstallString -match 'OfficeClickToRun')
            }
        }
    }

    return $entries | Group-Object RegistryPath | ForEach-Object { $_.Group[0] }
}
function Remove-OfficeResiduals {
    Stop-OfficeProcesses

    $pathsToRemove = @(
        "$env:ProgramFiles\Microsoft Office",
        "$env:ProgramFiles\Common Files\Microsoft Shared\ClickToRun",
        "$env:ProgramData\Microsoft\Office",
        "$env:LOCALAPPDATA\Microsoft\Office",
        "$env:APPDATA\Microsoft\Office"
    )

    if (${env:ProgramFiles(x86)}) {
        $pathsToRemove += "${env:ProgramFiles(x86)}\Microsoft Office"
        $pathsToRemove += "${env:ProgramFiles(x86)}\Common Files\Microsoft Shared\ClickToRun"
    }

    foreach ($path in $pathsToRemove | Select-Object -Unique) {
        if (-not $path -or -not (Test-Path $path)) { continue }
        Update-ProgressDialog "Entferne Restdateien" "$path"
        Remove-Item -Path $path -Recurse -Force
    }

    $registryPaths = @(
        'HKLM:\SOFTWARE\Microsoft\Office',
        'HKLM:\SOFTWARE\WOW6432Node\Microsoft\Office',
        'HKCU:\SOFTWARE\Microsoft\Office'
    )

    foreach ($registryPath in $registryPaths) {
        if (-not (Test-Path $registryPath)) { continue }
        Update-ProgressDialog "Entferne Registry-Reste: $registryPath"
        Remove-Item -Path $registryPath -Recurse -Force -ErrorAction SilentlyContinue
    }

    foreach ($entry in Get-OfficeUninstallEntries) {
        if (-not (Test-Path $entry.RegistryPath)) { continue }
        Update-ProgressDialog "Entferne verwaisten Uninstall-Eintrag" "$($entry.DisplayName)"
        Remove-Item -Path $entry.RegistryPath -Recurse -Force -ErrorAction SilentlyContinue
    }
}
function Resolve-OfficeUninstallCommand {
    param ( [string]$CommandLine )

    if (Test-Empty $CommandLine) { return $null }

    $trimmedCommand = $CommandLine.Trim()
    if ($trimmedCommand.StartsWith('"')) {
        $match = [regex]::Match($trimmedCommand, '^"(?<file>[^"]+)"\s*(?<args>.*)$')
        if (-not $match.Success) { return $null }
        $filePath   = $match.Groups['file'].Value
        $arguments  = $match.Groups['args'].Value
    } else {
        $parts      = $trimmedCommand -split '\s+', 2
        $filePath   = $parts[0]
        $arguments  = if ($parts.Count -gt 1) { $parts[1] } else { '' }
    }

    if ($filePath -match '(?i)OfficeClickToRun\.exe$') {
        # OfficeClickToRun erwartet eigene Schalter; generische /quiet-Argumente verursachen Fehler (z.B. ExitCode 17100).
        if ($arguments -notmatch '(?i)displaylevel\s*=\s*false')    { $arguments += ' displaylevel=false' }
        if ($arguments -notmatch '(?i)forceappshutdown\s*=\s*true') { $arguments += ' forceappshutdown=true' }
    } elseif ($filePath -match '(?i)msiexec(?:\.exe)?$') {
        if ($arguments -notmatch '(?i)(^|\s)/q(n|b|r|u|f|-)')   { $arguments += ' /qn' }
        if ($arguments -notmatch '(?i)/norestart')              { $arguments += ' /norestart' }
    } elseif ($arguments -notmatch '(?i)(/quiet|/passive|/silent|displaylevel\s*=\s*false)') {
        $arguments += ' /quiet /norestart'
    }

    return [PSCustomObject]@{
        FilePath    = $filePath
        Arguments   = $arguments.Trim()
    }
}
